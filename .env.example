# ============================================================
# Analytical-Force — Exemplo de variáveis de ambiente
# ------------------------------------------------------------
# Copie este arquivo para `.env` e preencha com valores reais.
# NUNCA faça commit do arquivo `.env` com credenciais.
#
# Regra crítica: o agente NÃO usa APIs comerciais pagas de LLM
# (OpenAI, Anthropic, Groq, Gemini). Apenas modelos locais/públicos.
# ============================================================

# ----------------------- Salesforce ------------------------
# Modo de autenticação. Métodos suportados:
#   oauth_refresh_token -> OAuth 2.0 Refresh Token (PADRÃO, recomendado).
#   soap_legacy         -> login() SOAP com usuário/senha/token (fallback).
# Algumas orgs bloqueiam o SOAP login() em versões recentes da API
# (erro INVALID_OPERATION), por isso o padrão é OAuth.
SALESFORCE_AUTH_MODE=oauth_refresh_token

SALESFORCE_INSTANCE_URL=https://pensotecnologia.my.salesforce.com
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REFRESH_TOKEN=
SALESFORCE_API_VERSION=64.0

# Modo somente leitura no Salesforce. Mantenha "true": o agente apenas
# consulta dados (SOQL). Nenhuma operação de escrita é implementada.
SALESFORCE_READ_ONLY_MODE=true

# Campos legados — usar apenas se SALESFORCE_AUTH_MODE=soap_legacy.
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
# Use "login" para produção e "test" para sandbox.
SALESFORCE_DOMAIN=login

# -------------------------- Turso --------------------------
# Banco principal do projeto (libSQL/Turso).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ------------------------- Modelo --------------------------
# Provider de modelo: template | ollama | transformers
#   template      -> relatório por regras, sem IA (sempre funciona).
#   ollama        -> modelo local via API HTTP do Ollama (recomendado).
#   transformers  -> modelo público via Hugging Face Transformers.
#
# Recomendação: comece com MODEL_PROVIDER=template para validar o
# pipeline de dados; depois mude para ollama para ativar a interpretação.
MODEL_PROVIDER=ollama

# Ollama local (não exige autenticação para acesso local).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Hugging Face Transformers (opcional). Sem modelo fixo no código.
HF_MODEL_REPO_ID=
HF_DEVICE=cpu
# Tokens gerados pelo modelo. Menor = mais rápido (em CPU faz muita diferença).
# 256–320 costuma bastar para o resumo executivo.
HF_MAX_NEW_TOKENS=320

# Inferência HOSPEDADA (MODEL_PROVIDER=hf_inference) — rápido e online, sem CPU.
# O modelo roda nos provedores roteados pela Hugging Face. Requer HF_TOKEN com
# permissão de Inference Providers. Free tier ~US$0,10/mês (suficiente p/ pouco uso).
HF_INFERENCE_MODEL=Qwen/Qwen2.5-7B-Instruct
# Provedor específico (ex.: together, fireworks-ai). Vazio = roteamento automático.
HF_INFERENCE_PROVIDER=
HF_TOKEN=

# Liga/desliga a interpretação por IA. Com "false", usa sempre template.
ENABLE_AI_INTERPRETATION=true

# ------------------------ Relatório ------------------------
REPORT_TIMEZONE=America/Sao_Paulo
# Destinatário PRINCIPAL do relatório (fixo, via env/Secret do Space).
REPORT_RECIPIENT_EMAIL=
# E-mails em CÓPIA (Cc) são cadastrados pelo painel (React) e persistidos no
# Turso (tabela agent_config, chave "email_cc_recipients") — não precisam de
# variável de ambiente nem de redeploy. Ver endpoints GET/POST/DELETE
# /config/email-cc em api.py.

# ---------------------- E-mail: SMTP (uso local) -----------
# Funciona localmente. Em Hugging Face Spaces o SMTP é BLOQUEADO — use a
# Gmail API (abaixo), que envia por HTTPS.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# ------------- E-mail: Gmail API (HTTP/OAuth) --------------
# Preferido em produção/online (passa por firewalls que bloqueiam SMTP).
# Como obter o refresh token: Google Cloud Console -> ativar "Gmail API" ->
# criar credencial OAuth -> no OAuth Playground (https://developers.google.com/oauthplayground)
# usar suas credenciais e autorizar o escopo
# https://www.googleapis.com/auth/gmail.send -> trocar pelo refresh token.
#
# ATENÇÃO: se a tela de consentimento OAuth do app no Google Cloud Console
# estiver em status "Testing" (não publicada), o refresh_token EXPIRA em
# ~7 dias e todo envio passa a falhar com RuntimeError/"invalid_grant" nos
# logs (é a causa mais comum desse erro). Publique o app (ou adicione os
# e-mails remetente/destinatário como "Test users" e gere um novo refresh
# token quando expirar) para evitar a expiração periódica.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# E-mail remetente (a conta autorizada no OAuth acima).
GMAIL_SENDER=

# --------------------- ClickUp (opcional) ------------------
CLICKUP_API_TOKEN=
CLICKUP_LIST_ID=
# Responsável das tarefas criadas. Informe o e-mail do membro (resolvido via
# API da lista) OU, preferencialmente, o ID numérico do usuário no ClickUp.
# Deixe em branco para criar tarefas sem responsável.
CLICKUP_ASSIGNEE_EMAIL=
CLICKUP_ASSIGNEE_ID=
# Criação automática de tarefas no ClickUp para alertas críticos.
# Mantenha "false" até validar manualmente o comportamento.
ENABLE_CLICKUP_AUTO_CREATE=false
# Gera um plano de ação por IA (Ollama) na descrição da tarefa. Requer
# MODEL_PROVIDER=ollama + ENABLE_AI_INTERPRETATION=true. false = só dados.
CLICKUP_AI_TASKS=true

# ------------------- Configurações de risco ----------------
LEAD_MAX_HOURS_WITHOUT_TASK=24
OPPORTUNITY_MAX_DAYS_WITHOUT_ACTIVITY=7
CONVERSION_DROP_THRESHOLD_PERCENT=20
PIPELINE_DROP_THRESHOLD_PERCENT=15
# Metas/limites adicionais usados pelo motor de risco.
LEAD_FIRST_TASK_TARGET_HOURS=8
OVERDUE_TASKS_OWNER_THRESHOLD=5
# Acima deste valor a oportunidade é considerada "alto valor".
HIGH_VALUE_OPPORTUNITY_AMOUNT=50000
# Valor MÍNIMO para a oportunidade entrar na análise (0 = todas).
OPPORTUNITY_MIN_AMOUNT=0
SATISFACTION_MIN_SCORE=7.0

# ------------- Campos customizados do Salesforce -----------
# Use os nomes de API EXATOS dos campos na sua org. Campos que não
# existirem são automaticamente ignorados (o agente valida via describe e
# registra um aviso em log), então deixe em branco os que sua org não tiver.
SF_FIELD_FIRST_TASK=FirstTask__c
# Campos de Opportunity são opcionais — preencha apenas se existirem na org.
SF_FIELD_OPP_MOTIVO_PERDA=
# Origem: deixe em branco para usar o campo padrão LeadSource.
SF_FIELD_OPP_ORIGEM=
SF_FIELD_OPP_TIPO_VENDA=
SF_FIELD_OPP_PRODUTO=
SF_FIELD_OPP_PROXIMA_ACAO=
SF_FIELD_OPP_DIAS_SEM_ATIVIDADE=
SF_FIELD_OPP_GC_NOME=
SF_FIELD_OPP_VALOR_MENSAL=

# ---- Fonte de Satisfação (módulo configurável) ----
# Objeto e campos da pesquisa de satisfação. Deixe SF_SAT_OBJECT em branco
# para manter o módulo desativado. O campo de sentimento é categórico e o
# agente deriva uma nota 0–10 (Verde=10, Amarelo=5, Vermelho=0).
SF_SAT_OBJECT=
SF_SAT_DATE_FIELD=Reply_Date__c
SF_SAT_SENTIMENT_FIELD=Sentimento__c
SF_SAT_REASON_FIELD=area_de_insatisfacao_motivador__c
SF_SAT_COMMENT_FIELD=Resumo__c
# Nota abaixo deste limite conta como avaliação negativa (detrator).
SF_SAT_NEGATIVE_THRESHOLD=5

# ---- Fonte de Cancelamento (módulo configurável) ----
# Por padrão, oportunidades com data de cancelamento no dia. Deixe
# SF_CANC_OBJECT em branco para manter o módulo desativado.
SF_CANC_OBJECT=
SF_CANC_DATE_FIELD=DATA_CANCELAMENTO__c
SF_CANC_MRR_FIELD=Valor_Liquido_Mensal__c
SF_CANC_REASON_FIELD=Motivo_Cancelamento__c
SF_CANC_PRODUCT_FIELD=ProdutoPrincipal__c
SF_CANC_OWNER_FIELD=GC_Nome__c

# ---- Fonte de Contratos (módulo de CONSULTA — busca somente leitura) ----
# Objetos usados pela tela de "Busca" do painel (contratos, itens de contrato
# e clientes). NÃO participa do pipeline diário de métricas — é lido sob
# demanda (busca ao vivo no Salesforce) e cacheado no Turso (busca híbrida).
SF_CONTRACT_OBJECT=Contrato_oPT__c
SF_CONTRACT_ITEM_OBJECT=Item_do_Contrato__c
# Nome de API do campo de LOOKUP do Contrato -> Account (ex.: "Conta__c").
# Deixe em branco se não souber: a busca de contratos por cliente fica
# desativada até você preencher (consulte Setup -> Gerenciador de Objetos ->
# Contrato_oPT__c -> Campos, e copie o "Nome de API" do campo de lookup).
SF_CONTRACT_ACCOUNT_FIELD=
# Nome de API do campo de LOOKUP do Item de Contrato -> Contrato (ex.:
# "Contrato__c"). Deixe em branco se não souber: a tela de detalhe do
# contrato não lista os itens vinculados até você preencher.
SF_CONTRACT_ITEM_PARENT_FIELD=
