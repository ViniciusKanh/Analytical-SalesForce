# ===== Segredos e ambiente =====
.env
*.env
!.env.example

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
# Excecao: o painel React precisa do build comitado para a Vercel servir
# "/" (o deploy Python da Vercel nao roda "npm run build" automaticamente).
!frontend-react/dist/
!frontend-react/dist/**
.venv/
venv/
env/

# ===== Banco local / dados =====
*.db
*.sqlite
*.sqlite3
data/exports/*
!data/exports/.gitkeep

# ===== Logs =====
logs/*.log
!logs/.gitkeep

# ===== Relatórios gerados =====
reports/daily/*.md
!reports/daily/.gitkeep

# ===== IDE / SO =====
.idea/
.vscode/
.DS_Store
Thumbs.db

